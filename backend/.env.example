# backend/.env 템플릿. 이 파일을 .env로 복사해서 값을 채운다.
# .env는 커밋하지 않는다(.gitignore).

# 필수. 없으면 부팅이 실패한다.
# JWT 서명 키 — 기본값을 두지 않는 이유는, 리포지토리에 적힌 키로 누구나
# 관리자 토큰을 서명할 수 있게 되기 때문이다. 배포마다 다른 임의값을 쓴다.
JWT_SECRET=change-me
DATABASE_URL=postgresql://user:password@localhost:5432/playsync

# 선택. 아래는 코드상의 기본값과 같다.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
PORT=3001

# 리바인 대기 제한(ms).
REBUY_TIMEOUT_MS=15000

# WebSocket Origin 허용 목록(쉼표 구분).
WS_ALLOWED_ORIGINS=http://localhost:3000
